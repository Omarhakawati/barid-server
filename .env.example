# ─────────────────────────────────────────────
#  بريد — Environment Variables
#  Copy this file to .env and fill in your keys
# ─────────────────────────────────────────────

# Twitter / X API
# Get yours at: https://developer.twitter.com/en/portal/dashboard
# You need a FREE account — Basic tier ($100/mo) for higher limits
# Free tier gives 1 app, read-only, 500k tweets/month
X_BEARER_TOKEN=your_x_bearer_token_here

# Server
PORT=3000

# How long to cache data before re-fetching (seconds)
# RSS:     600  = 10 minutes
# Twitter: 900  = 15 minutes (X rate limits: 15 req / 15 min on free tier)
RSS_CACHE_TTL=600
X_CACHE_TTL=900

# Optional: restrict which origins can call this server
# Leave empty to allow all (fine for local dev)
ALLOWED_ORIGIN=
